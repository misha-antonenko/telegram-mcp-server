# Telegram API Credentials (Required - get from https://my.telegram.org/apps)
API_ID=123456
API_HASH=0123456789abcdef0123456789abcdef

# Your Telegram user ID (get via @userinfobot or similar)
OWNER_ID=

# Session Management (use SESSION_STRING for Docker deployments)
# Generate with: python session_string_generator.py
SESSION_STRING=

# Domain name for TLS (Let's Encrypt via Caddy)
MCP_DOMAIN=example.com

# GitHub OAuth App credentials (create at https://github.com/settings/developers)
# Callback URL: https://<MCP_DOMAIN>:2197/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Persistent JWT signing key — tokens survive server restarts.
# Generate with: openssl rand -base64 32
GITHUB_JWT_SIGNING_KEY=

# Fallback: static bearer token (used when GitHub OAuth is not configured)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=
